#!/usr/bin/env php
<?php

declare(strict_types=1);

require __DIR__ . '/vendor/autoload.php';

use App\Core\Console\Commands\MigrateCommand;
use App\Core\Console\Commands\RollbackCommand;
use App\Core\Console\Commands\FreshCommand;
use App\Core\Console\Commands\StatusCommand;
use App\Core\Console\Commands\MakeMigrationCommand;
use App\Core\Console\Commands\SeedCommand;
use App\Core\Console\Commands\MailSendVerificationCommand;
use App\Core\Console\Commands\MailSendResetPasswordCommand;
use App\Core\Console\Commands\RecalculateFlashSaleSoldCommand;

$envPath = __DIR__ . '/.env';
if (file_exists($envPath)) {
    $dotenv = Dotenv\Dotenv::createImmutable(__DIR__);
    $dotenv->load();
}

$argv = $_SERVER['argv'];
$command = $argv[1] ?? null;
$args = array_slice($argv, 2);

$commands = [
    'migrate'                        => MigrateCommand::class,
    'migrate:rollback'               => RollbackCommand::class,
    'migrate:fresh'                  => FreshCommand::class,
    'migrate:status'                 => StatusCommand::class,
    'make:migration'                 => MakeMigrationCommand::class,
    'db:seed'                        => SeedCommand::class,
    'mail:send-verification'        => MailSendVerificationCommand::class,
    'mail:send-reset-password'      => MailSendResetPasswordCommand::class,
    'flashsale:recalculate-sold'    => RecalculateFlashSaleSoldCommand::class,
];

if ($command === null || ! isset($commands[$command])) {
    echo "Ecommerce PHP CLI\n\n";
    echo "Perintah yang tersedia:\n";
    foreach (array_keys($commands) as $name) {
        echo "  {$name}\n";
    }
    echo "\nContoh: php cli migrate\n";

    exit($command === null ? 0 : 1);
}

try {
    $handler = new $commands[$command]();
    $exitCode = $handler->handle($args);

    exit($exitCode ?? 0);
} catch (\Throwable $e) {
    echo "\nError: " . $e->getMessage() . "\n";

    if (env('APP_DEBUG', false)) {
        echo $e->getTraceAsString() . "\n";
    }

    exit(1);
}