{
    "name": "trio/ecommerce-php",
    "description": "Native PHP E-Commerce - Modular DDD Monolith with Tailwind, Alpine.js, HTMX, iPaymu & Biteship",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.9",
        "monolog/monolog": "^3.7",
        "phpmailer/phpmailer": "^6.9",
        "resend/resend-php": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Core\\": "src/Core/",
            "App\\Shared\\": "src/Shared/",
            "App\\Modules\\Auth\\": "src/Modules/Auth/",
            "App\\Modules\\Banner\\": "src/Modules/Banner/",
            "App\\Modules\\Wishlist\\": "src/Modules/Wishlist/",
            "App\\Modules\\Coupon\\": "src/Modules/Coupon/",
            "App\\Modules\\FlashSale\\": "src/Modules/FlashSale/",
            "App\\Modules\\Page\\": "src/Modules/Page/",
            "App\\Modules\\Product\\": "src/Modules/Product/",
            "App\\Modules\\Category\\": "src/Modules/Category/",
            "App\\Modules\\Customer\\": "src/Modules/Customer/",
            "App\\Modules\\Cart\\": "src/Modules/Cart/",
            "App\\Modules\\Dashboard\\": "src/Modules/Dashboard/",
            "App\\Modules\\Dev\\": "src/Modules/Dev/",
            "App\\Modules\\Order\\": "src/Modules/Order/",
            "App\\Modules\\Payment\\": "src/Modules/Payment/",
            "App\\Modules\\Shipping\\": "src/Modules/Shipping/",
            "App\\Modules\\Search\\": "src/Modules/Search/",
            "App\\Modules\\Setting\\": "src/Modules/Setting/",
            "App\\Modules\\Inventory\\": "src/Modules/Inventory/",
            "App\\Modules\\Review\\": "src/Modules/Review/",
            "Database\\Migrations\\": "database/migrations/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/"
        },
        "files": [
            "src/Core/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8080 -t public"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
