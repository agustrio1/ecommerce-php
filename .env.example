APP_NAME="Ecommerce PHP"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecommerce_php
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

# iPaymu Payment Gateway
IPAYMU_MODE=sandbox
IPAYMU_VA=
IPAYMU_API_KEY=
IPAYMU_SANDBOX_URL=https://sandbox.ipaymu.com/api/v2
IPAYMU_PRODUCTION_URL=https://my.ipaymu.com/api/v2

# Biteship Shipping
BITESHIP_API_KEY=
BITESHIP_BASE_URL=https://api.biteship.com/v1
BITESHIP_ORIGIN_AREA_ID=

# Mail (opsional, untuk notifikasi order)
MAIL_DRIVER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@ecommerce.test
MAIL_FROM_NAME="Ecommerce PHP"
